# =============================================================================
# ForgeAI environment configuration
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# `.env` is gitignored and must never be committed.
# =============================================================================

# ---- App ----
ENVIRONMENT=development          # development | production
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
LOG_LEVEL=INFO

# ---- Datastores ----
# Hostnames (postgres/redis/qdrant/ollama) resolve on the docker-compose network.
# When running the API on the host instead of in Docker, swap them for localhost.
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forgeai
DATABASE_URL=postgresql+psycopg://forge:forge@postgres:5432/forgeai

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://qdrant:6333

OLLAMA_URL=http://ollama:11434
# LLM request timeout in seconds (increase on slow/local hardware)
OLLAMA_TIMEOUT=600

# ---- Auth ----
# Generate a strong value for real use, e.g.  openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- Model routing (local, via Ollama) ----
# No OpenAI key. No Claude key. Everything runs locally for the MVP.
# Provider: "ollama" (real local models) or "echo" (deterministic + instant —
# for demos/CI on hardware that can't run the models).
MODEL_PROVIDER=ollama
MODEL_PLANNER=qwen3:8b
MODEL_CODER=deepseek-coder
MODEL_RESEARCH=llama3.1:8b
MODEL_EMBED=nomic-embed-text

# ---- GitHub integration ----
# A Personal Access Token (classic, repo scope) for the MVP. Leave blank to run
# ForgeAI without GitHub; integration features are then disabled.
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com
# Shared secret for verifying inbound GitHub webhooks (X-Hub-Signature-256).
GITHUB_WEBHOOK_SECRET=

# Auto-propose PRs to this repo after successful agent runs (requires GITHUB_TOKEN).
GITHUB_OWNER=
GITHUB_REPO=

# Author identity for git commits pushed to GitHub (Docker has no global git config).
GIT_AUTHOR_NAME=ForgeAI
GIT_AUTHOR_EMAIL=forgeai@users.noreply.github.com

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
